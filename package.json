{
  "name": "plantuml-viewer",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "install:ci": "bash scripts/install-ci.sh",
    "prepare:plantuml": "node scripts/prepare-plantuml-assets.mjs",
    "predev": "npm run prepare:plantuml",
    "dev": "vite",
    "prebuild": "npm run prepare:plantuml",
    "build": "bash scripts/build-verified.sh",
    "build:pages": "npm run prepare:plantuml && next build",
    "start": "vinext start",
    "test": "npm run build && node --test tests/rendered-html.test.mjs",
    "test:pages": "npm run build:pages && node --test tests/static-export.test.mjs",
    "validate:artifact": "bash scripts/validate-artifact.sh",
    "lint": "bash scripts/sites-env.sh -- eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern 'public/plantuml/*.js'"
  },
  "dependencies": {
    "@plantuml/core": "^1.2026.6",
    "lucide-react": "^1.24.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module",
  "displayName": "MassiveDyno UML Canvas"
}
